# Environment Variables Template for AgriScope Backend
# Copy this file to .env and fill in your actual values

# JWT Secret Key (use a strong, random secret)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google Gemini AI API Key for crop recommendations
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Database Configuration
# Get these values from your Supabase project settings: https://supabase.com/dashboard
# Navigate to: Settings > Database > Connection string (PostgreSQL)
DB_HOST=your-project.supabase.co
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_NAME=postgres
DB_PORT=5432

# For production deployment - copy the connection string from Supabase
# Supabase dashboard: Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:your-password@your-project.supabase.co:5432/postgres

# Server Configuration
PORT=5000
NODE_ENV=development

# For production deployment platforms
# Heroku automatically sets DATABASE_URL, so you only need JWT_SECRET there
